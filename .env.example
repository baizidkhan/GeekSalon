# ─────────────────────────────────────────────────────────────────────────────
# makeover-client — Environment variables
#
# Copy this file to .env before running docker-compose.prod.yml:
#   cp .env.example .env
#
# IMPORTANT: NEXT_PUBLIC_API_BASE_URL is baked into the Next.js JS bundle at
# build time. If you change this value you must rebuild the image:
#   docker compose -f docker-compose.prod.yml up --build -d
# ─────────────────────────────────────────────────────────────────────────────

# Public URL of the API server as seen by the browser (client-side fetches).
# Use the server's public IP and the Traefik makeover-api entrypoint port.
NEXT_PUBLIC_API_BASE_URL=http://YOUR_SERVER_IP:4000
